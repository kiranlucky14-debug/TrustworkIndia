generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  FREELANCER
  ADMIN
}

enum JobStatus {
  CREATED
  ASSIGNED
  FUNDED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  COMPLETED
  DISPUTED
  CANCELLED
  JOB_WITHDRAWN
  REFUND_PENDING
  REFUNDED
}

enum EscrowStatus {
  LOCKED
  RELEASED
  REFUNDED
}

enum MilestoneStatus {
  LOCKED
  UNLOCKED
  PENDING
  FUNDED
  SUBMITTED
  CLIENT_APPROVED
  UNDER_ADMIN_REVIEW
  PENDING_REVIEW
  APPROVED
  RELEASED
  REFUNDED
}

enum TransactionType {
  DEPOSIT
  RELEASE
  REFUND
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  CLOSED
}

model User {
  id          String   @id @default(uuid())
  name        String
  phone       String   @unique
  role        Role     @default(CLIENT)
  rating      Float    @default(0)
  ratingCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Profile completion
  profileCompleted  Boolean @default(false)
  isVerified        Boolean @default(false)

  // Auth
  passwordHash      String?
  userId            String?  @unique   // TW-000001 format
  resetToken        String?
  resetTokenExpiry  DateTime?
  lastLoginAt       DateTime?
  loginAttempts     Int      @default(0)
  lockedUntil       DateTime?
  suspended         Boolean   @default(false)
  suspendReason     String?
  suspendedAt       DateTime?

  // Contact & location
  email        String?  @unique
  city         String?
  state        String?
  country      String?  @default("India")
  pincode      String?
  addressLine1 String?
  addressLine2 String?

  // Professional
  bio               String?
  designation       String?
  title             String?
  experienceLevel   String?
  yearsOfExperience Int?
  portfolioUrl      String?
  linkedinUrl       String?
  githubUrl         String?
  instagramUrl      String?
  facebookUrl       String?
  profilePhoto      String?
  resumeUrl         String?
  hourlyRate        Decimal? @db.Decimal(10, 2)
  demoRate          Decimal? @db.Decimal(10, 2)
  trustScore        Int      @default(0)

  // Business (Client)
  companyName  String?
  businessType String?
  gstNumber    String?
  panNumber    String?
  cinNumber    String?
  aadhaarNumber String?
  website      String?
  companyLogo  String?
  panDocument  String?
  gstDocument  String?

  // Payments
  preferredPayment String? @default("UPI")
  upiId            String?
  bankHolderName   String?
  bankName         String?
  accountNumber    String?
  ifscCode         String?

  clientJobs     Job[]         @relation("ClientJobs")
  freelancerJobs Job[]         @relation("FreelancerJobs")
  transactions   Transaction[]
  disputes       Dispute[]
  otps           OTP[]
  skills         UserSkill[]
  reviewsGiven    Review[]         @relation("ReviewFrom")
  reviewsReceived Review[]         @relation("ReviewTo")
  applications             JobApplication[]
  notifications            Notification[]
  payoutQueues             PayoutQueue[]
  adminLogs                AdminLog[]    @relation("AdminLogs")
  agreedAsClient           WorkAgreement[] @relation("AgreementClientSig")
  agreedAsFreelancer       WorkAgreement[] @relation("AgreementFreelancerSig")
}

model OTP {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  userId String?
}

model Job {
  id          String    @id @default(uuid())
  title       String
  description String
  budget      Float
  deadline    DateTime
  status      JobStatus @default(CREATED)
  createdAt   DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  agreementStatus  String?
  withdrawnAt      DateTime?
  withdrawReason   String?
  withdrawnById    String?

  client       User    @relation("ClientJobs", fields: [clientId], references: [id])
  clientId     String
  freelancer   User?   @relation("FreelancerJobs", fields: [freelancerId], references: [id])
  freelancerId String?

  // One job -> many escrow rows (one per milestone)
  // Use escrows[] when milestones are active; legacy single-escrow code
  // still works because it creates one escrow with milestoneId = null
  escrows           Escrow[]
  dispute           Dispute?
  applicants        JobApplication[]
  milestones        Milestone[]
  skills            JobSkill[]
  reviews           Review[]
  agreement         WorkAgreement?
  agreementVersions AgreementVersion[]
  payoutQueues      PayoutQueue[]
}

model JobApplication {
  id          String   @id @default(uuid())
  jobId       String
  userId      String
  message     String?
  status      String   @default("PENDING")
  shortlisted Boolean  @default(false)
  createdAt   DateTime @default(now())

  job  Job  @relation(fields: [jobId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
}

// Each escrow row is linked to ONE milestone (milestone-based)
// OR has milestoneId = null (legacy whole-job escrow)
model Escrow {
  id          String       @id @default(uuid())
  jobId       String
  amount      Float
  status      EscrowStatus @default(LOCKED)
  paymentId        String?
  orderId          String?
  milestoneId      String?      @unique
  platformFeeRate  Decimal?     @db.Decimal(5, 4)
  platformFee      Decimal?     @db.Decimal(12, 2)
  netAmount        Decimal?     @db.Decimal(12, 2)   // null = legacy; set = milestone escrow
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  job       Job        @relation(fields: [jobId], references: [id])
  milestone Milestone? @relation(fields: [milestoneId], references: [id])

  @@index([jobId])
}

model Milestone {
  id             String          @id @default(uuid())
  jobId          String
  title          String
  description    String?
  deliverable    String?
  amount         Float
  status         MilestoneStatus @default(PENDING)
  order          Int
  dueDate        DateTime?
  submittedAt    DateTime?
  submissionNote String?
  approvedAt     DateTime?
  approvedById   String?
  payoutStatus   String          @default("UNPAID")   // UNPAID | PENDING_REVIEW | APPROVED | REJECTED | RELEASED
  payoutApprovedAt DateTime?
  payoutApprovedBy String?
  payoutRejectedAt DateTime?
  payoutRejectNote String?
  platformFee      Decimal?        @db.Decimal(12, 2)
  netAmount        Decimal?        @db.Decimal(12, 2)
  isLocked         Boolean         @default(true)
  unlockedAt       DateTime?
  clientApprovedAt DateTime?
  adminReviewAt    DateTime?
  releasedAt       DateTime?
  rejectedAt       DateTime?
  rejectReason     String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  job         Job          @relation(fields: [jobId], references: [id])
  escrow      Escrow?
  payoutQueue PayoutQueue?

  @@index([jobId])
  @@index([jobId, order])
}

model Transaction {
  id          String            @id @default(uuid())
  userId      String
  amount      Float
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  reference   String?
  milestoneId String?
  description String?
  platformFee Decimal?          @db.Decimal(12, 2)
  netAmount   Decimal?          @db.Decimal(12, 2)
  createdAt   DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Dispute {
  id         String        @id @default(uuid())
  jobId      String        @unique
  raisedById String
  reason     String
  status     DisputeStatus @default(OPEN)
  resolution String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  job      Job  @relation(fields: [jobId], references: [id])
  raisedBy User @relation(fields: [raisedById], references: [id])
}

model Skill {
  id        String     @id @default(uuid())
  name      String     @unique
  category  String     @default("General")
  createdAt DateTime   @default(now())

  jobSkills  JobSkill[]
  userSkills UserSkill[]
}

model JobSkill {
  jobId   String
  skillId String

  job   Job   @relation(fields: [jobId],   references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
}

model UserSkill {
  userId  String
  skillId String

  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
}

model Review {
  id            String   @id @default(uuid())
  jobId         String
  fromId        String
  toId          String
  quality       Int
  communication Int
  timeliness    Int
  overall       Float
  comment       String?
  createdAt     DateTime @default(now())

  job  Job  @relation(fields: [jobId],   references: [id], onDelete: Cascade)
  from User @relation("ReviewFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("ReviewTo",   fields: [toId],   references: [id], onDelete: Cascade)

  @@unique([jobId, fromId])
  @@index([toId])
  @@index([jobId])
}

model WorkAgreement {
  id     String @id @default(uuid())
  jobId  String @unique
  status String @default("DRAFT")

  // Section A
  scope              String?
  deliverables       Json    @default("[]")
  startDate          DateTime?
  endDate            DateTime?
  revisionRounds     Int     @default(2)
  revisionPolicy     String?
  paymentTerms       String?
  specialConditions  String?

  // Section B
  milestonesAgreed   Json    @default("[]")

  // Section C
  escrowTermsAccepted Boolean @default(false)

  // Section D
  clientChecklist     Json    @default("{}")
  freelancerChecklist Json    @default("{}")

  // Phase 2: Re-confirmation at submission and release
  freelancerSubmitConfirmedAt  DateTime?
  submissionNote               String?
  clientReleaseConfirmedAt     DateTime?
  releaseNote                  String?

  // Signatures
  clientSignedAt      DateTime?
  clientSignedById    String?
  freelancerSignedAt  DateTime?
  freelancerSignedById String?
  agreedAt            DateTime?

  // Versioning
  version      Int     @default(1)
  parentId     String?
  superseded   Boolean @default(false)

  // Phase 3: PDF certificate
  pdfGeneratedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job              Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  clientSigned     User? @relation("AgreementClientSig",     fields: [clientSignedById],     references: [id])
  freelancerSigned User? @relation("AgreementFreelancerSig", fields: [freelancerSignedById],  references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // ASSIGNED | AGREEMENT_PENDING | AGREEMENT_SIGNED | FUNDED | SUBMITTED | APPROVED | REJECTED | CHANGES_REQUESTED
  title     String
  message   String
  jobId     String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  target    String?
  targetId  String?
  before    Json?
  after     Json?
  note      String?
  ip        String?
  createdAt DateTime @default(now())

  admin User @relation("AdminLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
}

model AgreementVersion {
  id            String   @id @default(uuid())
  jobId         String
  agreementId   String
  version       Int
  changedBy     String
  changeReason  String?
  snapshotJson  Json     @default("{}")
  createdAt     DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([agreementId])
}

model PayoutQueue {
  id              String   @id @default(uuid())
  milestoneId     String   @unique
  jobId           String
  freelancerId    String
  grossAmount     Decimal  @db.Decimal(12, 2)
  platformFeeRate Decimal  @db.Decimal(5, 4)  @default(0.02)
  platformFee     Decimal  @db.Decimal(12, 2)
  netAmount       Decimal  @db.Decimal(12, 2)
  status          String   @default("PENDING_REVIEW")  // PENDING_REVIEW | APPROVED | REJECTED | RELEASED
  adminNote       String?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  milestone  Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  freelancer User      @relation(fields: [freelancerId], references: [id])

  @@index([status])
  @@index([jobId])
  @@index([freelancerId])
}
