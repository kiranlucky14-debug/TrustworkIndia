# ─── Database ────────────────────────────────────────────────────────
# Format: postgresql://USER:Qwerty@123@HOST:PORT/DATABASE
# Replace USER and PASSWORD with your actual PostgreSQL credentials
DATABASE_URL="postgresql://postgres:Qwerty@123@localhost:5432/trustwork"

# ─── Auth ────────────────────────────────────────────────────────────
JWT_SECRET="trustwork-super-secret-jwt-key-change-in-production-2024"
JWT_EXPIRES_IN="7d"

# ─── Server ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5174"

# ─── Razorpay (leave as-is for demo/mock mode) ───────────────────────
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"
