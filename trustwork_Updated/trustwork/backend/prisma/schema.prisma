generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  FREELANCER
  ADMIN
}

enum JobStatus {
  CREATED
  ASSIGNED
  FUNDED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  COMPLETED
  DISPUTED
  CANCELLED
}

enum EscrowStatus {
  LOCKED
  RELEASED
  REFUNDED
}

enum MilestoneStatus {
  PENDING
  FUNDED
  RELEASED
  REFUNDED
}

enum TransactionType {
  DEPOSIT
  RELEASE
  REFUND
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  CLOSED
}

enum JobType {
  FIXED
  HOURLY
}

model User {
  id          String   @id @default(uuid())
  name        String
  phone       String   @unique
  role        Role     @default(CLIENT)
  rating      Float    @default(0)
  ratingCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clientJobs     Job[]         @relation("ClientJobs")
  freelancerJobs Job[]         @relation("FreelancerJobs")
  transactions   Transaction[]
  disputes       Dispute[]
  otps           OTP[]
  skills         UserSkill[]
}

model OTP {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  userId String?
}

model Job {
  id          String    @id @default(uuid())
  title       String
  description String
  budget      Float
  deadline    DateTime
  status      JobStatus @default(CREATED)
  category   String?  @default("General")
  type       JobType  @default(FIXED)
  isRemote   Boolean  @default(true)
  hourlyRate Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client       User    @relation("ClientJobs", fields: [clientId], references: [id])
  clientId     String
  freelancer   User?   @relation("FreelancerJobs", fields: [freelancerId], references: [id])
  freelancerId String?

  // One job -> many escrow rows (one per milestone)
  // Use escrows[] when milestones are active; legacy single-escrow code
  // still works because it creates one escrow with milestoneId = null
  escrows    Escrow[]
  dispute    Dispute?
  applicants JobApplication[]
  milestones Milestone[]
  skills     JobSkill[]
}

model JobApplication {
  id        String   @id @default(uuid())
  jobId     String
  userId    String
  message   String?
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id])

  @@unique([jobId, userId])
}

// Each escrow row is linked to ONE milestone (milestone-based)
// OR has milestoneId = null (legacy whole-job escrow)
model Escrow {
  id          String       @id @default(uuid())
  jobId       String
  amount      Float
  status      EscrowStatus @default(LOCKED)
  paymentId   String?
  orderId     String?
  milestoneId String?      @unique   // null = legacy; set = milestone escrow
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  job       Job        @relation(fields: [jobId], references: [id])
  milestone Milestone? @relation(fields: [milestoneId], references: [id])

  @@index([jobId])
}

model Milestone {
  id        String          @id @default(uuid())
  jobId     String
  title     String
  amount    Float
  status    MilestoneStatus @default(PENDING)
  order     Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  job    Job     @relation(fields: [jobId], references: [id])
  escrow Escrow?

  @@index([jobId])
  @@index([jobId, order])
}

model Transaction {
  id          String            @id @default(uuid())
  userId      String
  amount      Float
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  reference   String?
  milestoneId String?
  createdAt   DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Dispute {
  id         String        @id @default(uuid())
  jobId      String        @unique
  raisedById String
  reason     String
  status     DisputeStatus @default(OPEN)
  resolution String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  job      Job  @relation(fields: [jobId], references: [id])
  raisedBy User @relation(fields: [raisedById], references: [id])
}

model Skill {
  id        String     @id @default(uuid())
  name      String     @unique
  category  String     @default("General")
  createdAt DateTime   @default(now())

  jobSkills  JobSkill[]
  userSkills UserSkill[]
}

model JobSkill {
  jobId   String
  skillId String

  job   Job   @relation(fields: [jobId],   references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
}

model UserSkill {
  userId  String
  skillId String

  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
}
