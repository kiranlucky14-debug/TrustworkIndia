# ═══════════════════════════════════════════════════════════════
#  TrustWork Backend — Environment Configuration
#  Copy this to .env and fill in your actual values.
#  NEVER commit .env to Git.
# ═══════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/trustwork"
# Production example:
# DATABASE_URL="postgresql://trustwork_user:STRONG_PASSWORD@db.yourhost.com:5432/trustwork?sslmode=require"

# ── Auth ─────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_64_CHARACTER_RANDOM_HEX_STRING"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
LOG_LEVEL=info
LOG_DIR=logs

# ── CORS ─────────────────────────────────────────────────────────
FRONTEND_URL="https://yourdomain.com"
# Multiple origins (comma-separated):
# ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"

# ── Razorpay ─────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
# Test keys: rzp_test_xxx  |  Live keys: rzp_live_xxx
RAZORPAY_KEY_ID="rzp_live_YOUR_KEY_ID"
RAZORPAY_KEY_SECRET="YOUR_KEY_SECRET"
RAZORPAY_WEBHOOK_SECRET="YOUR_WEBHOOK_SECRET"

# ── OTP / SMS ────────────────────────────────────────────────────
# Provider options: mock | msg91 | twilio | fast2sms
OTP_PROVIDER="mock"

# MSG91 (popular in India)
# MSG91_AUTH_KEY=""
# MSG91_SENDER_ID="TRSTW"
# MSG91_TEMPLATE_ID=""

# Twilio
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

# Fast2SMS (cheapest India option)
# FAST2SMS_API_KEY=""

# ── Email ─────────────────────────────────────────────────────────
# Provider options: mock | smtp | sendgrid | resend
EMAIL_PROVIDER="mock"
EMAIL_FROM="noreply@yourdomain.com"
EMAIL_FROM_NAME="TrustWork"

# SMTP (Gmail, Zoho, etc.)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your@gmail.com"
# SMTP_PASS="your_app_password"

# SendGrid
# SENDGRID_API_KEY=""

# Resend (recommended — simple API)
# RESEND_API_KEY=""

# ── Redis (for Socket.io scaling + caching) ───────────────────────
# Required for multi-instance deployment
# REDIS_URL="redis://localhost:6379"

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MIN=15
