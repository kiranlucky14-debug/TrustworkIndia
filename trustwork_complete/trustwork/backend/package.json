{
  "name": "trustwork-backend",
  "version": "1.0.0",
  "description": "TrustWork Freelancer Escrow Platform - Backend",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "setup": "prisma generate && prisma migrate dev --name init && node prisma/seed.js",
    "seed:categories": "node prisma/seedJobCategories.js",
    "seed:all": "node prisma/seed.js && node prisma/skillsSeed.js && node prisma/seedJobCategories.js",
    "start:prod": "NODE_ENV=production node app.js",
    "start:pm2": "pm2 start ecosystem.config.js"
  },
  "dependencies": {
    "@prisma/client": "5.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.4",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "razorpay": "^2.9.2",
    "uuid": "^9.0.1",
    "socket.io": "^4.7.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.2.0",
    "compression": "^1.7.4",
    "winston": "^3.13.0",
    "morgan": "^1.10.0",
    "xss": "^1.0.15",
    "nodemailer": "^6.9.13"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "5.10.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}